# -- Tiny settings
TINY_APP_DIR=app
# TINY_AUTOLOAD_HELPERS=cypher,utils
TINY_CALC_TIMER=true
TINY_COOKIE_TTL=31536000
TINY_CURL_TIMEOUT=5
TINY_DEBUG_WHITELIST="*" # only show debug info to these ips (comma separated)
TINY_DIR=tiny # location of "tiny" directory
TINY_HOMEPAGE=home
TINY_LOG_FILE=~/tiny.log
TINY_LOG_LEVEL=debug
TINY_MINIFY_OUTPUT=false # minify html output
TINY_STATIC_DIR=static # location of "static" directory (cdn url or path relative to index.php)
TINY_TIMEZONE=UTC
TINY_CACHE_DISABLED=false # only on dev
TINY_CACHE_PREFIX='aroussi'

# -- Set these if not automatically detected
# TINY_APP_PATH=/path/to/app
# TINY_CMS_DIR=/path/to/app/cms-md-files
# TINY_COOKIE_DOMAIN=localhost
# TINY_COOKIE_PATH=/
# TINY_PATH=/path/to/tiny
# TINY_PUBLIC_PATH=/path/to/html
# TINY_URL_PATH=/

# -- Sentry settings
# SENTRY_DSN=
# SENTRY_FRONTEND=
# SENTRY_SAMPLE_RATE=1.0

# ---------------------------
# Tiny module settings
# ---------------------------

# -- Cypher
# TINY_CRYPTO_ALGO=aes-256-cbc
# TINY_CRYPTO_SECRET=
