 require_once __DIR__ . '/ext/utils.php';
 require_once __DIR__ . '/tiny.php';

if (PHP_SAPI === 'cli' && str_ends_with(__FILE__, $argv[0])) {

    if ($argc < 2) {
        echo "Usage: php tiny/cli [category] [?options]\n";
        exit(1);
    }

    $category = $argv[1];
    if ($category === 'create') {
        $projectName = $argv[2] ?? null;
        $targetDir = $projectName ? __DIR__ . '/../' . $projectName : __DIR__ . '/..';
        $targetDir = realpath($targetDir) ?: $targetDir;

        if ($projectName && !is_dir($targetDir)) {
            mkdir($targetDir, 0755, true);
        }

        echo "Fetching boilerplate branch...\n";

        $tempDir = sys_get_temp_dir() . '/tiny-boilerplate-' . time();
        $cmd = sprintf(
            'git clone --depth 1 -b boilerplate https://github.com/ranaroussi/tiny.git %s 2>&1',
            escapeshellarg($tempDir)
        );
        exec($cmd, $output, $returnCode);

        if ($returnCode !== 0) {
            echo "[✗] Failed to fetch boilerplate branch.\n" . implode("\n", $output) . "\n";
            exit(1);
        }

        // Copy boilerplate files to target (skip .git)
        $items = new DirectoryIterator($tempDir);
        foreach ($items as $item) {
            if ($item->isDot()) continue;
            $basename = $item->getBasename();
            if ($basename === '.git') continue;

            $src = $item->getPathname();
            $dst = $targetDir . '/' . $basename;

            if (is_dir($dst)) {
                tiny::rrmdir($dst);
            } elseif (file_exists($dst)) {
                unlink($dst);
            }
            rename($src, $dst);
        }

        tiny::rrmdir($tempDir);

        $displayPath = $projectName ?? basename(realpath(__DIR__ . '/..'));

        if ($projectName) {
            echo "[✓] Project created at {$displayPath}/ 🎉\n\n";
            echo "Next steps:\n";
            echo "  cd {$displayPath}\n";
            echo "  git init\n";
            echo "  git submodule add -b tiny https://github.com/ranaroussi/tiny.git tiny\n";
            echo "  git submodule update --init\n";
        } else {
            echo "[✓] Project created successfully 🎉\n\n";
            echo "Next steps:\n";
            echo "  git init\n";
            echo "  git submodule add -b tiny https://github.com/ranaroussi/tiny.git tiny\n";
            echo "  git submodule update --init\n";
        }

        echo "  composer install\n";
        echo "  cd buildtools && npm install\n";
        echo "  cp env.example .env.local\n";
        echo "  docker-compose up\n";
        exit(0);
    }

    if ($category === 'migrations') {
        require_once __DIR__ . '/ext/migration.php';

        $migration = new TinyMigration();
        if ($argc < 3) {
            echo "Usage: php migration.php [create|up|down|remove] [name]\n";
            exit(1);
        }
        $command = $argv[2];
        switch ($command) {
            case 'create':
                if ($argc < 4) {
                    echo "Please provide a name for the migration.\n";
                    exit(1);
                }
                $migration->create($argv[3]);
                break;
            case 'up':
                $migration->up();
                break;
            case 'down':
                $migration->down();
                break;
            case 'remove':
                if ($argc < 4) {
                    echo "Please provide a name for the migration to remove.\n";
                    exit(1);
                }
                $migration->remove($argv[3]);
                break;
            default:
                echo "Invalid command. Use 'create', 'up', 'down', or 'remove'.\n";
                exit(1);
        }
    }
}
